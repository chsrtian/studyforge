APP_NAME=StudyForge
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=studyforge
DB_USERNAME=studyforge
DB_PASSWORD=replace_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=your-domain.example
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=240

FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace_me
MAIL_PASSWORD=replace_me
MAIL_FROM_ADDRESS="noreply@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AI_PROVIDER=gemini
AI_MOCK_MODE=false
AI_FALLBACK_ON_PROVIDER_FAILURE=true
AI_MONTHLY_TOKEN_LIMIT=500000
AI_DAILY_TOKEN_LIMIT=25000
QUEUE_HEALTH_TOKEN=replace_with_random_token

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEXT_TIMEOUT=30
OPENAI_JSON_TIMEOUT=40
OPENAI_CONNECT_TIMEOUT=10
OPENAI_RETRIES=2
OPENAI_RETRY_DELAY_MS=750

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEXT_TIMEOUT=30
GEMINI_JSON_TIMEOUT=40
GEMINI_CONNECT_TIMEOUT=10
GEMINI_RETRIES=2
GEMINI_RETRY_DELAY_MS=750
